# Production build config (Vite reads these at `vercel --prod` / `npm run build`).
# Replace the API URL with your deployed Railway backend URL, OR set these as
# Environment Variables in the Vercel project dashboard (recommended) and delete this file.
VITE_API_URL=https://REPLACE-WITH-RAILWAY-URL.up.railway.app
VITE_DEFAULT_ORG=acmecorp

# Copy to .env.local and fill in values from 1Password vault "Engineering Local Dev"

# ── Database ──────────────────────────────────────────────────────────────────
# Pooled connection (PgBouncer) — use for all app queries
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/acmecorp_dev

# Unpooled — required by Drizzle for migrations only
DATABASE_URL_DIRECT=postgresql://postgres:postgres@localhost:5432/acmecorp_dev

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Feature flags (LaunchDarkly) ──────────────────────────────────────────────
LAUNCHDARKLY_SDK_KEY=sdk-...
NEXT_PUBLIC_LAUNCHDARKLY_CLIENT_ID=...

# ── Background jobs (Trigger.dev) ─────────────────────────────────────────────
TRIGGER_API_KEY=tr_dev_...
TRIGGER_API_URL=https://api.trigger.dev

# ── Caching ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Observability ─────────────────────────────────────────────────────────────
DATADOG_API_KEY=
SENTRY_DSN=

# ── Webhooks ──────────────────────────────────────────────────────────────────
SVIX_WEBHOOK_SECRET=whsec_...

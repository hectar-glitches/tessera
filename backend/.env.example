# Anthropic — optional. Without it, generation falls back to a deterministic stub.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MODEL_SMALL=claude-3-5-haiku-20241022

# Redis — optional. Without it, an in-memory store is used.
REDIS_URL=redis://localhost:6379

# Embeddings
EMBED_MODEL=all-MiniLM-L6-v2

# Decision thresholds (cosine similarity, 0..1)
SIM_HIT=0.55        # >= this AND entity/focus match -> instant cache hit
SIM_SUGGEST=0.40    # >= this (but below hit, or entity/focus mismatch) -> suggest popup

# Pricing (USD per 1M tokens) used for savings accounting
PRICE_INPUT_PER_M=3.00
PRICE_OUTPUT_PER_M=15.00
